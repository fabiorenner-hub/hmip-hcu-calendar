{
  "name": "hmip-hcu-calendar",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "description": "Homematic IP HCU plugin that exposes calendar special days (German holidays, bridge days, school holidays, custom days) as virtual on/off devices.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build:server": "tsc -p tsconfig.json",
    "build:spa": "node esbuild.mjs",
    "make:icon": "node scripts/make-icon.mjs",
    "build": "npm run clean && npm run build:server && npm run build:spa",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.spa.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "node dist/bootstrap/loader.js",
    "build:image": "node scripts/build-image.mjs",
    "build:ota": "node scripts/build-ota.mjs stable",
    "build:ota:exp": "node scripts/build-ota.mjs experimental",
    "publish:ota:exp": "pwsh -File scripts/publish-ota-experimental.ps1"
  },
  "dependencies": {
    "fastify": "^4.28.1",
    "@fastify/static": "^7.0.4",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.23.0",
    "preact": "^10.22.1",
    "@preact/signals": "^1.3.0",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5",
    "fast-check": "^3.21.0",
    "eslint": "^8.57.0",
    "@typescript-eslint/parser": "^7.16.1",
    "@typescript-eslint/eslint-plugin": "^7.16.1",
    "prettier": "^3.3.3"
  }
}
